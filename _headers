  X-Content-Type-Options: nosniff
  X-DNS-Prefetch-Control: off
  X-Permitted-Cross-Domain-Policies: none
  X-XSS-Protection: 0
  Referrer-Policy: no-referrer
  Permissions-Policy: interest-cohort=(), camera=(), microphone=(), geolocation=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=(), bluetooth=(), midi=(), serial=(), hid=(), display-capture=(), idle-detection=(), sync-xhr=(), screen-wake-lock=(), web-share=(), xr-spatial-tracking=(), clipboard-read=(), clipboard-write=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Cache-Control: no-store, no-cache, must-revalidate, private
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet, noimageindex
  Server-Timing: dossier608

/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
